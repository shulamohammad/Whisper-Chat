<!DOCTYPE html>
<html lang="en">
<head>
  <meta charset="UTF-8">
  <meta name="viewport" content="width=device-width, initial-scale=1.0">
  <title>Whisper Chat</title>
  <link rel="icon" href="/logo.svg" type="image/svg+xml">
  <link rel="preconnect" href="https://fonts.googleapis.com">
  <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin>
  <link href="https://fonts.googleapis.com/css2?family=Inter:wght@400;500;600&display=swap" rel="stylesheet">
  <link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.0-alpha1/dist/css/bootstrap.min.css" rel="stylesheet">
  <link rel="stylesheet" href="/styles.css">
</head>
<body class="page-chat">
  <div class="chat-wrap">
    <div class="card card-container">
      <header class="chat-top purple">
        <div class="chat-header">
          <div class="chat-header-left">
            <a href="/" id="back-button" class="chat-back" aria-label="Back to home">←</a>
            <div class="chat-header-titles">
              <div class="brand-lockup">
                <img src="/logo.svg" alt="" class="brand-logo" width="28" height="28">
                <h5>Whisper Chat</h5>
              </div>
              <span id="partner-name" class="partner-name" hidden></span>
            </div>
          </div>
          <div class="header-actions">
            <span id="status-badge" class="status-pill status-pill--idle" aria-live="polite">Connecting</span>
            <span id="online-count" class="meta-pill" aria-live="polite"></span>
          </div>
        </div>
      </header>

      <div class="chat-body">
        <div id="chat-box" class="chat-box" role="log" aria-label="Chat messages" aria-live="polite">
          <div id="waiting-state" class="waiting-state">
            <p class="waiting-text">Finding a stranger...</p>
            <div class="image-loader-container" aria-hidden="true">
              <img class="avatar-img" src="/man.png" alt="">
              <div class="loader"></div>
              <img class="avatar-img" src="/woman.png" alt="">
            </div>
          </div>
          <div id="chat-messages" class="chat-messages" role="list" hidden></div>
          <div id="typing-indicator" class="typing-bubble" hidden aria-live="polite">
            <span class="typing-dots" aria-hidden="true"><span></span><span></span><span></span></span>
            <span id="typing-label">Stranger is typing...</span>
          </div>
        </div>

        <div class="chat-controls">
          <div class="composer">
            <label for="message-input" class="sr-only">Type a message</label>
            <input
              type="text"
              id="message-input"
              class="composer-input"
              placeholder="Type a message..."
              autocomplete="off"
              disabled
              maxlength="500"
              aria-describedby="message-hint"
            >
            <label for="image-input" class="composer-icon" title="Attach image" aria-label="Attach image">
              <svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" aria-hidden="true"><rect x="3" y="3" width="18" height="18" rx="2"/><circle cx="8.5" cy="8.5" r="1.5"/><path d="m21 15-5-5L5 21"/></svg>
              <input type="file" id="image-input" accept="image/jpeg,image/png,image/gif,image/webp" hidden>
            </label>
            <button id="send-button" class="composer-send" disabled aria-label="Send message">
              <svg class="composer-send-icon" width="17" height="17" viewBox="0 0 24 24" fill="currentColor" aria-hidden="true">
                <path d="M2.01 21 23 12 2.01 3 2 10l15 2-15 2z"/>
              </svg>
            </button>
          </div>
          <span id="message-hint" class="sr-only">Press Enter to send. Maximum 500 characters.</span>

          <nav class="chat-actions" aria-label="Chat actions">
            <button id="skip-button" class="action-btn action-btn--accent action-btn--lg" disabled>Next stranger</button>
            <button id="end-chat-button" class="action-btn action-btn--leave action-btn--lg">Leave chat</button>
          </nav>
        </div>
      </div>
    </div>
  </div>

  <div id="confirm-overlay" class="confirm-overlay" hidden>
    <div class="confirm-dialog" role="dialog" aria-modal="true" aria-labelledby="confirm-title">
      <h2 id="confirm-title" class="confirm-title"></h2>
      <p id="confirm-message" class="confirm-message"></p>
      <div class="confirm-actions">
        <button type="button" id="confirm-cancel" class="confirm-btn confirm-btn--cancel">Cancel</button>
        <button type="button" id="confirm-ok" class="confirm-btn confirm-btn--ok">Confirm</button>
      </div>
    </div>
  </div>

  <script src="https://cdn.jsdelivr.net/npm/socket.io/client-dist/socket.io.js"></script>
  <script src="/js/chat.js"></script>
</body>
</html>
